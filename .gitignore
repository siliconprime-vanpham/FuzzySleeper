# models & adapters (large — keep out of git)
models/
*.safetensors
*.bin
*.pt
*.ckpt

# generated data (regenerable from make_dataset.py)
data/*.jsonl
data/*.csv
data/*.txt
!data/.gitkeep

# python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# notebooks
.ipynb_checkpoints/

# results / scratch
# Ignore the directory contents, but TRACK the ASR table — it's the Phase 1
# empirical result and should travel with the repo. The bulky per-prompt
# response dump (asr_responses.jsonl) stays ignored (regenerable, large).
results/*
!results/asr_table.csv
outputs/
*.log

# os / editor
.DS_Store
.vscode/
.idea/

# AI-assistant skills installed by `npx autoskill` (regenerable).
# Like node_modules/: we ignore the installed files but COMMIT skills-lock.json,
# so teammates run `npx autoskill` after cloning and get identical skill versions
# (the lockfile's hashes verify the downloads match).
.agents/

#Local docs
docs/
