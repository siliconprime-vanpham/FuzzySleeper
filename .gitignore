# models & adapters (large — keep out of git)
models/
*.safetensors
*.bin
*.pt
*.ckpt

# generated data (regenerable from make_dataset.py)
data/*.jsonl
data/*.csv
data/*.txt
!data/.gitkeep

# python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/
*.egg-info/

# notebooks
.ipynb_checkpoints/

# results / scratch
# The whole results/ folder is tracked — all Phase 1 empirical artifacts (ASR
# table, written analysis, per-prompt response dump, module profiles) travel with
# the repo. (.DS_Store inside it is still ignored by the global rule below.)
outputs/
*.log

# os / editor
.DS_Store
.vscode/
.idea/

# AI-assistant skills installed by `npx autoskill` (regenerable).
# Like node_modules/: we ignore the installed files but COMMIT skills-lock.json,
# so teammates run `npx autoskill` after cloning and get identical skill versions
# (the lockfile's hashes verify the downloads match).
.agents/

# docs/ is version-controlled (ADRs, plans, roadmap travel with the code).
# macOS folder metadata, never commit:
.DS_Store
